# ─── OpenAvail configuration ──────────────────────────────────────────────
# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Google OAuth Web Client ID (public — safe to expose in the browser).
# Create one at https://console.cloud.google.com/apis/credentials
#   → OAuth client ID → Web application
#   → add your site origin(s) under "Authorized JavaScript origins".
# No client *secret* is needed: OpenAvail uses the Google Identity Services
# ID-token flow and verifies the token server-side.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# The Google account email that owns this instance and gets admin powers
# (create/revoke invites, manage members). The first sign-in with this email
# becomes the admin.
ADMIN_EMAIL=you@gmail.com

# Display name used for branding the locked landing page, e.g. "Marcel" →
# "Marcel's OpenAvail". Served to the browser via GET /api/config so changing
# it needs no rebuild.
OWNER_NAME=Marcel

# Public base URL of the deployment, used to build invite links.
# e.g. https://avail.example.com
PUBLIC_URL=http://localhost:5173

# Path to the SQLite database file (the directory is created automatically).
DB_PATH=./data/openavail.db

# API server port.
PORT=8787

# node environment: development | production
# In production the session cookie is marked Secure (requires HTTPS).
NODE_ENV=development
